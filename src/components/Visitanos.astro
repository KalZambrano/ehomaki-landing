---
import SectionContainer from "./SectionContainer.astro";
import { EhomakiMap } from "./cards/EhomakiMap.tsx";
import CarIcon from "@/assets/icons/car.svg";
import BusIcon from "@/assets/icons/bus.svg";
import LocationIcon from "@/assets/icons/map-marker.svg";
import PhoneIcon from "@/assets/icons/phone-call.svg";
import { ClockIcon } from "lucide-react";
---

<SectionContainer
  title="Visítanos"
  subtitle="Nuestra ubicación"
  name="visitanos"
>
  <div
    class="flex flex-col md:flex-row justify-center items-center md:justify-between gap-3"
  >
    <address
      class="
      flex flex-col items-center md:items-start gap-3 not-italic
      [&>a]:w-fit
      "
    >
      <a
        href="#"
        class="flex items-center gap-2 rounded-full border border-(--gold)/20 bg-(--gold)/10 px-4 py-2"
      >
        <LocationIcon class="size-5 text-(--gold)" />
        <span>Av. Alameda Los Cedros 366</span>
      </a>

      <a
        href="https://wa.me/51941442899"
        class="flex items-center gap-2 rounded-full border border-green-500/20 bg-green-500/10 px-4 py-2"
      >
        <PhoneIcon class="size-5 text-green-500" />
        <span>+51 941 442 899</span>
      </a>
    </address>
    <section class="text-center md:text-right">
      <h2
        class="mb-3 flex justify-center md:justify-end items-center gap-1.5 text-(--gold)"
      >
        <ClockIcon className="size-4.5" />
        Horarios de Atención
      </h2>

      <ul
        class="space-y-2
      [&_time]:inline-block
      [&_time]:px-2
      [&_time]:py-0.5
      [&_time]:mx-1
      [&_time]:rounded-md
      [&_time]:bg-(--gold)/10
      [&_time]:border
      [&_time]:border-(--gold)/20
      [&_time]:font-semibold
      [&_time]:text-(--gold)"
      >
        <li>Lunes – Sábado <time>12:00pm</time> a <time>10:00pm</time></li>
        <li>Domingos <time>12:00pm</time> a <time>06:00pm</time></li>
      </ul>
    </section>
  </div>

  <section class="m-auto mt-4 flex max-w-328.75 flex-row flex-wrap gap-8 p-4">
    <figure
      class="relative h-70 md:h-157.5 min-w-75 flex-1 overflow-hidden rounded-[1.5rem] bg-black"
    >
      <EhomakiMap client:idle />
    </figure>
    <section
      class="flex w-full shrink-0 flex-col gap-y-8 overflow-hidden md:w-93.75 lg:w-137.5"
    >
      {/* TRANSPORTE PÚBLICO */}
      <article class="flex flex-col gap-3 px-4">
        <h3
          class="mb-1 flex w-fit items-center gap-x-2 rounded-[2rem] bg-white px-4 py-2 text-base font-bold text-black"
        >
          <BusIcon class="size-4" />
          Transporte público
        </h3>

        <p class="text-white/80 leading-relaxed">
          Toma buses o combis por la <span class="text-white font-medium"
            >Av. Alameda Los Cedros</span
          >,
          <span class="text-white font-medium">Av. Huaylas</span> o
          <span class="text-white font-medium">Av. Prolongación Huaylas</span>.
          Baja en Cedros de Villa y camina unas cuadras hasta el local.
        </p>

        <aside
          class="rounded-xl border border-white/10 bg-white/5 px-4 py-3 flex flex-col gap-1"
        >
          <span
            class="text-xs font-semibold tracking-widest text-white/50 uppercase"
            >Desde otra zona de Lima</span
          >
          <p class="text-white/80 leading-relaxed text-sm">
            Metropolitano hasta <span class="text-white font-medium"
              >estación Matellini</span
            >, luego taxi o combi hacia Cedros de Villa. También puedes usar
            <span class="text-white font-medium">Uber, Didi o InDriver</span> directo
            al local.
          </p>
        </aside>
      </article>

      {/* COCHE PROPIO */}
      <article class="flex flex-col gap-3 px-4">
        <h3
          class="mb-1 flex w-fit items-center gap-x-2 rounded-[2rem] bg-white px-4 py-2 text-base font-bold text-black"
        >
          <CarIcon class="size-4" />
          En coche propio
        </h3>

        <ol class="flex flex-col gap-2 list-none">
          <li
            class="flex items-start gap-3 rounded-xl border border-white/10 bg-white/5 px-4 py-3"
          >
            <span
              class="mt-0.5 text-xs font-bold tracking-widest text-white/50 uppercase w-6 shrink-0"
              >01</span
            >
            <div>
              <span class="text-white font-medium text-sm">Av. Huaylas</span>
              <p class="text-white/60 text-sm">
                Vía principal para entrar a Chorrillos desde el norte.
              </p>
            </div>
          </li>
          <li
            class="flex items-start gap-3 rounded-xl border border-white/10 bg-white/5 px-4 py-3"
          >
            <span
              class="mt-0.5 text-xs font-bold tracking-widest text-white/50 uppercase w-6 shrink-0"
              >02</span
            >
            <div>
              <span class="text-white font-medium text-sm"
                >Alameda Los Cedros</span
              >
              <p class="text-white/60 text-sm">
                Acceso directo al local, el número es 366.
              </p>
            </div>
          </li>
          <li
            class="flex items-start gap-3 rounded-xl border border-white/10 bg-white/5 px-4 py-3"
          >
            <span
              class="mt-0.5 text-xs font-bold tracking-widest text-white/50 uppercase w-6 shrink-0"
              >03</span
            >
            <div>
              <span class="text-white font-medium text-sm"
                >Prolongación Huaylas</span
              >
              <p class="text-white/60 text-sm">
                Conexión desde Villa El Salvador y el sur de Lima.
              </p>
            </div>
          </li>
        </ol>

        <a
          href="https://maps.app.goo.gl/Y72cvyUB26ebGzMH6"
          target="_blank"
          rel="noopener noreferrer"
          class="mt-1 flex items-center justify-between gap-2 rounded-xl border border-white/20 bg-white/5 px-4 py-3 transition hover:bg-white/10 group"
        >
          <div class="flex flex-col gap-0.5">
            <span
              class="text-xs font-semibold tracking-widest text-white/50 uppercase"
              >Abrir en Google Maps / Waze</span
            >
            <span class="text-white/80 text-sm"
              >"Ehomakis Sushi Bar — Cedros de Villa"</span
            >
          </div>
          <svg
            class="shrink-0 text-white/30 transition group-hover:text-white/70 group-hover:translate-x-1"
            width="18"
            height="18"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="1.5"
          >
            <path d="M5 12h14M13 6l6 6-6 6"></path>
          </svg>
        </a>

        <p class="text-xs text-white/50 px-1">
          Hay opciones de estacionamiento en la zona — se recomienda revisar el
          tráfico en horas punta.
        </p>
      </article>
    </section>
  </section>
</SectionContainer>
