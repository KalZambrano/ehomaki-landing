---
import JapaneseCastle from "../assets/icons/japanese-castle.svg";
import FishIcon from "../assets/icons/fish.svg";
import StarIcon from "../assets/icons/star.svg";
import ChevronRight from "../assets/icons/chevron-right.svg";
import ChevronLeft from "../assets/icons/chevron-left.svg";

const STATCARDS = [
  {
    icon: JapaneseCastle,
    label: "Nuestra filosofía",
    value:
      "Fusión honesta entre la tradición japonesa y los sabores que crecimos comiendo en Lima. Cada roll cuenta una historia.",
  },
  {
    icon: FishIcon,
    label: "Frescura garantizada",
    value:
      "Trabajamos con proveedores seleccionados. El salmón, la trucha y los mariscos llegan diariamente para que cada pieza sea perfecta.",
  },
  {
    icon: StarIcon,
    label: "Experiencia única",
    value:
      "Cada roll es una obra de arte culinaria. Desde 2018, llevamos la cocina Nikkei a mesas que nunca habían probado el encuentro entre el ají amarillo y el salmón.",
  },
];
---

<section
  id="info"
  class="relative overflow-hidden
    border-y border-[#1b1812]
    bg-[#090806]
    py-12 md:py-16"
>
  {/* Ambient glow */}
  <div
    class="pointer-events-none absolute inset-0 opacity-40
      [background:radial-gradient(circle_at_top,rgba(200,155,60,0.08),transparent_40%)]"
  >
  </div>

  {/* Desktop */}
  <div
    class="relative z-10 hidden
      mx-auto max-w-7xl
      md:grid md:grid-cols-3"
  >
    {
      STATCARDS.map((card, index) => (
        <div
          class={`
          group relative flex flex-col items-center text-center
          px-10 py-8
          ${index !== 2 ? "border-r border-[#1c1913]" : ""}
        `}
        >
          {/* Decorative vertical glow */}
          <div
            class="
            absolute inset-y-10 right-0 w-px
            bg-linear-to-b from-transparent via-[#c89b3c]/20 to-transparent
          "
          />

          {/* Icon wrap */}
          <div
            class="
            relative mb-8 flex h-24 w-24 items-center justify-center
            rounded-full border border-[#2a2418]
            bg-[#0f0d09]
            transition-all duration-500
            group-hover:border-[#c89b3c]/40
            group-hover:bg-[#15110c]
          "
          >
            <div
              class="
              absolute inset-0 rounded-full opacity-0
              transition-opacity duration-500
              group-hover:opacity-100
              shadow-[0_0_40px_rgba(200,155,60,0.18)]
            "
            />

            <card.icon
              class="
              relative z-10 size-10
              transition-transform duration-500
              group-hover:scale-110
            "
            />
          </div>

          {/* Label */}
          <div
            class="
            relative mb-6 inline-flex items-center justify-center
          "
          >
            <div
              class="
              absolute inset-0
              -rotate-1 skew-x-[-8deg]
              rounded-sm
              bg-[#c89b3c]
            "
            />

            <span
              class="
              relative z-10
              px-5 py-2
              text-[11px] font-bold
              uppercase tracking-[0.35em]
              text-black
            "
            >
              {card.label}
            </span>
          </div>

          {/* Mini divider */}
          <div
            class="
            mb-6 flex items-center gap-2
          "
          >
            <div class="h-px w-8 bg-[#c89b3c]/30" />
            <div class="size-1 rounded-full bg-[#c89b3c]" />
            <div class="h-px w-8 bg-[#c89b3c]/30" />
          </div>

          {/* Text */}
          <p
            class="
            max-w-85
            font-['Noto_Serif_JP']
            text-[15px]
            leading-loose
            text-[#e8e1d5]
          "
          >
            {card.value}
          </p>
        </div>
      ))
    }
  </div>

  {/* MOBILE SLIDER */}
  <div class="relative z-10 md:hidden">
    <div
      id="info-slider"
      class="flex transition-transform duration-500 ease-out"
    >
      {
        STATCARDS.map((card) => (
          <div class="min-w-full px-6">
            <div
              class="
              relative overflow-hidden
              rounded-[28px]
              border border-[#1f1b14]
              bg-[#0d0b08]
              p-8
              text-center
            "
            >
              {/* Glow */}
              <div
                class="
                absolute inset-0 opacity-40
                [background:radial-gradient(circle_at_top,rgba(200,155,60,0.12),transparent_60%)]
              "
              />

              {/* Icon */}
              <div
                class="
                relative z-10 mx-auto mb-6
                flex h-20 w-20 items-center justify-center
                rounded-full
                border border-[#2a2418]
                bg-[#14110c]
              "
              >
                <card.icon class="size-8" />
              </div>

              {/* Label */}
              <div class="relative z-10 mb-5 inline-flex">
                <div
                  class="
                  absolute inset-0
                  -rotate-1 skew-x-[-8deg]
                  bg-[#c89b3c]
                "
                />

                <span
                  class="
                  relative z-10
                  px-4 py-2
                  text-[10px] font-bold
                  uppercase tracking-[0.3em]
                  text-black
                "
                >
                  {card.label}
                </span>
              </div>

              {/* Text */}
              <p
                class="
                relative z-10
                font-['Noto_Serif_JP']
                text-[15px]
                leading-[1.9]
                text-[#ece6dc]
              "
              >
                {card.value}
              </p>
            </div>
          </div>
        ))
      }
    </div>

    {/* Controls */}
    <div class="mt-8 flex items-center justify-center gap-6">
      <button
        type="button"
        id="info-prev"
        aria-label="Anterior"
        class="flex size-10 items-center justify-center
          rounded-full border border-[#2a2418]
          bg-[#0f0d09]
          text-white/60
          transition-all duration-300
          hover:border-[#c89b3c]/40
          hover:text-[#c89b3c]"
      >
        <ChevronLeft class="size-4" />
      </button>

      <div class="flex items-center gap-2" id="info-dots">
        <button
          type="button"
          data-dot="0"
          class="info-dot h-2 w-8 rounded-full
            bg-[#c89b3c]
            transition-all duration-300"
        ></button>

        <button
          type="button"
          data-dot="1"
          class="info-dot size-2 rounded-full
            bg-white/20
            transition-all duration-300"
        ></button>

        <button
          type="button"
          data-dot="2"
          class="info-dot size-2 rounded-full
            bg-white/20
            transition-all duration-300"
        ></button>
      </div>

      <button
        type="button"
        id="info-next"
        aria-label="Siguiente"
        class="flex size-10 items-center justify-center
          rounded-full border border-[#2a2418]
          bg-[#0f0d09]
          text-white/60
          transition-all duration-300
          hover:border-[#c89b3c]/40
          hover:text-[#c89b3c]"
      >
        <ChevronRight class="size-4" />
      </button>
    </div>
  </div>
</section>

<script>
  const slider = document.getElementById("info-slider");
  const dots = document.querySelectorAll(".info-dot");
  const prev = document.getElementById("info-prev");
  const next = document.getElementById("info-next");

  let current = 0;
  const total = 3;

  function goTo(index) {
    current = (index + total) % total;

    slider.style.transform = `translateX(-${current * 100}%)`;

    dots.forEach((dot, i) => {
      const active = i === current;

      dot.classList.toggle("w-8", active);
      dot.classList.toggle("h-2", active);
      dot.classList.toggle("bg-[#c89b3c]", active);

      dot.classList.toggle("size-2", !active);
      dot.classList.toggle("bg-white/20", !active);
    });
  }

  prev?.addEventListener("click", () => goTo(current - 1));
  next?.addEventListener("click", () => goTo(current + 1));

  dots.forEach((dot) => {
    dot.addEventListener("click", () => {
      goTo(Number(dot.dataset.dot));
    });
  });

  // Swipe
  let startX = 0;

  slider?.addEventListener(
    "touchstart",
    (e) => {
      startX = e.touches[0].clientX;
    },
    { passive: true },
  );

  slider?.addEventListener("touchend", (e) => {
    const diff = startX - e.changedTouches[0].clientX;

    if (Math.abs(diff) > 40) {
      goTo(diff > 0 ? current + 1 : current - 1);
    }
  });
</script>
