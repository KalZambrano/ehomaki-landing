---

<SectionContainer title="Nuestros Makis" subtitle="Carta" name="menu">
  <div class="menu-tabs">
    <button class="tab-btn active" data-cat="makis">Makis</button>
    <button class="tab-btn" data-cat="entradas">Entradas</button>
  </div>
  <div class="menu-grid" id="menuGrid">
    <!-- Makis -->
    {MENU_ITEMS.map((item) => <MenuCard item={item} />)}
  </div>
</SectionContainer>

<style>
  /* ── MENU SECTION ── */
  #menu {
    padding: 6rem 4rem;
    position: relative;
  }

  .menu-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    margin-bottom: 4rem;
  }

  .menu-tabs {
    display: flex;
    gap: 0.25rem;
    background: var(--dark);
    padding: 0.25rem;
    border: 1px solid var(--border);
  }

  .tab-btn {
    background: none;
    border: none;
    color: var(--muted);
    font-family: "DM Sans", sans-serif;
    font-size: 0.72rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    padding: 0.5rem 1.25rem;
    cursor: pointer;
    transition: all 0.2s;
  }
  .tab-btn.active {
    background: var(--gold);
    color: var(--black);
  }

  .menu-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5px;
    background: var(--border);
  }
</style>

<script>
  // Mostrar makis por defecto al cargar la página
  const tabBtns = document.querySelectorAll(".tab-btn");
  const allCards = document.querySelectorAll(".menu-card");

  // estado inicial (makis)
  allCards.forEach((card) => {
    if (card.dataset.cat !== "makis") {
      card.classList.add("hidden");
    }
  });

  tabBtns.forEach((btn) => {
    btn.addEventListener("click", () => {
      const category = btn.dataset.cat;

      tabBtns.forEach((b) => b.classList.remove("active"));
      btn.classList.add("active");

      allCards.forEach((card) => {
        if (card.dataset.cat === category) {
          card.classList.remove("hidden");
        } else {
          card.classList.add("hidden");
        }
      });
    });
  });

  // ── TABS ──
  document.querySelectorAll(".tab-btn").forEach((tab) => {
    tab.addEventListener("click", () => {
      document
        .querySelectorAll(".tab-btn")
        .forEach((t) => t.classList.remove("active"));
      tab.classList.add("active");
      const cat = tab.dataset.cat;
      document.querySelectorAll(".menu-card").forEach((card) => {
        card.classList.toggle("visible", card.dataset.cat === cat);
      });
    });
  });
</script>
