---
import Header from "../components/Header.astro";
import Hero from "../components/Hero.astro";
import Footer from "../components/Footer.astro";
import Menu from "../components/Menu.astro";
import Galeria from "../components/Galeria.astro";
import AboutUs from "../components/AboutUs.astro";
import Combos from "../components/Combos.astro";
import CartSection from "./CartSection.astro";
import Visitanos from "./Visitanos.astro";
import { CommentsMarquee } from "../components/CommentsMarquee";
import { AdMarquee } from "../components/AdMarquee";
---

<CartSection />

<Header />
<Hero />
<AdMarquee client:idle />
<Menu />
<Combos />
<AboutUs />
<CommentsMarquee client:idle />
<Visitanos />
<Galeria />
<Footer />

<!-- TOAST -->
<div
  class="toast"
  id="toast"
  role="status"
  aria-live="polite"
  aria-atomic="true"
>
</div>

<style>
  /* ── TOAST ── */
  .toast {
    position: fixed;
    bottom: 2rem;
    left: 50%;
    transform: translateX(-50%) translateY(80px);
    background: var(--card);
    border: 1px solid var(--gold);
    color: var(--white);
    padding: 0.75rem 2rem;
    font-size: 0.8rem;
    letter-spacing: 0.05em;
    z-index: 500;
    transition: transform 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
    white-space: nowrap;
  }
  .toast.show {
    transform: translateX(-50%) translateY(0);
  }

  /* ── REVEAL ANIMATIONS ── */
  .reveal {
    opacity: 0;
    transform: translateY(30px);
    transition:
      opacity 0.7s,
      transform 0.7s;
  }
  .reveal.visible {
    opacity: 1;
    transform: translateY(0);
  }
</style>

<script>
  // @ts-nocheck
  /**
   * @typedef {{id:string,name:string,price:number,img:string,qty:number}} CartItem
   */

  /** @type {CartItem[]} */
  let cart = [];

  const toast = /** @type {HTMLElement | null} */ (
    document.getElementById("toast")
  );
  let toastTimer = /** @type {ReturnType<typeof setTimeout> | null} */ (null);

  const showToast = (msg) => {
    if (!toast) return;
    toast.textContent = msg;
    toast.classList.add("show");
    if (toastTimer) clearTimeout(toastTimer);
    toastTimer = setTimeout(() => toast.classList.remove("show"), 2000);
  };

  const initCart = () => {
    const cartCount = /** @type {HTMLElement | null} */ (
      document.getElementById("cartCount")
    );
    const cartItemsEl = /** @type {HTMLElement | null} */ (
      document.getElementById("cartItems")
    );
    const cartEmpty = /** @type {HTMLElement | null} */ (
      document.getElementById("cartEmpty")
    );
    const cartFooter = /** @type {HTMLElement | null} */ (
      document.getElementById("cartFooter")
    );
    const cartSubtotal = /** @type {HTMLElement | null} */ (
      document.getElementById("cartSubtotal")
    );
    const cartTotal = /** @type {HTMLElement | null} */ (
      document.getElementById("cartTotal")
    );

    if (
      !cartCount ||
      !cartItemsEl ||
      !cartEmpty ||
      !cartFooter ||
      !cartSubtotal ||
      !cartTotal
    ) {
      return;
    }

    const renderCart = () => {
      const total = cart.reduce((sum, item) => sum + item.price * item.qty, 0);
      cartCount.textContent = String(
        cart.reduce((sum, item) => sum + item.qty, 0),
      );

      if (cart.length === 0) {
        cartEmpty.style.display = "block";
        cartFooter.style.display = "none";
        Array.from(cartItemsEl.querySelectorAll(".cart-item")).forEach((el) =>
          el.remove(),
        );
        return;
      }

      cartEmpty.style.display = "none";
      cartFooter.style.display = "block";
      cartSubtotal.textContent = `S/ ${total.toFixed(2)}`;
      cartTotal.textContent = `S/ ${total.toFixed(2)}`;

      Array.from(cartItemsEl.querySelectorAll(".cart-item")).forEach((el) =>
        el.remove(),
      );

      cart.forEach((item) => {
        const el = document.createElement("div");
        el.className = "cart-item";
        el.dataset.id = item.id;
        el.innerHTML = `
          <div class="ci-img-wrap">
            <img src="${item.img}" alt="${item.name}" />
            <button type="button" class="remove-btn" data-id="${item.id}">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="icon icon-tabler icons-tabler-outline icon-tabler-trash">
                <path stroke="none" d="M0 0h24v24H0z" fill="none" />
                <path d="M4 7l16 0" />
                <path d="M10 11l0 6" />
                <path d="M14 11l0 6" />
                <path d="M5 7l1 12a2 2 0 0 0 2 2h8a2 2 0 0 0 2 -2l1 -12" />
                <path d="M9 7v-3a1 1 0 0 1 1 -1h4a1 1 0 0 1 1 1v3" />
              </svg>
            </button>
          </div>
          <div>
            <div class="ci-name">${item.name}</div>
            ${item.qty > 1 ? `<div class="ci-unit-price">S/ ${item.price.toFixed(2)} c/u</div>` : ""}
            <div class="ci-price">S/ ${(item.price * item.qty).toFixed(2)}</div>
          </div>
          <div class="ci-controls">
            <div class="qty-controls">
              <button type="button" class="qty-btn" data-action="dec" data-id="${item.id}" ${item.qty === 1 ? "disabled" : ""}>−</button>
              <span class="qty-num">${item.qty}</span>
              <button type="button" class="qty-btn" data-action="inc" data-id="${item.id}">+</button>
            </div>
          </div>
        `;
        cartItemsEl.appendChild(el);
      });
    };

    /**
     * @param {string} id
     * @param {string} name
     * @param {string} price
     * @param {string} img
     */
    const addToCart = (id, name, price, img) => {
      const existing = cart.find((item) => item.id === id);
      if (existing) {
        existing.qty++;
      } else {
        cart.push({ id, name, price: parseFloat(price), img, qty: 1 });
      }
      renderCart();
      showToast(`${name} agregado ✓`);
    };

    cartItemsEl.addEventListener("click", (event) => {
      if (!(event.target instanceof HTMLElement)) return;
      const id = event.target.dataset.id;
      if (!id) return;

      if (event.target.dataset.action === "inc") {
        const item = cart.find((cartItem) => cartItem.id === id);
        if (item) {
          item.qty++;
          renderCart();
        }
      } else if (event.target.dataset.action === "dec") {
        const item = cart.find((cartItem) => cartItem.id === id);
        if (item) {
          if (item.qty > 1) {
            item.qty--;
          } else {
            cart = cart.filter((cartItem) => cartItem.id !== id);
          }
          renderCart();
        }
      } else if (event.target.classList.contains("remove-btn")) {
        cart = cart.filter((cartItem) => cartItem.id !== id);
        renderCart();
      }
    });

    const checkoutBtn = /** @type {HTMLButtonElement | null} */ (
      document.getElementById("checkoutBtn")
    );
    checkoutBtn?.addEventListener("click", () => {
      if (cart.length === 0) return;
      const lines = cart
        .map(
          (item) =>
            `• ${item.name} x${item.qty} — S/ ${(item.price * item.qty).toFixed(2)}`,
        )
        .join("\n");
      const total = cart
        .reduce((sum, item) => sum + item.price * item.qty, 0)
        .toFixed(2);
      const msg = `¡Hola! Quiero hacer el siguiente pedido:\n\n${lines}\n\n*Total: S/ ${total}*\n\n¿Pueden confirmar disponibilidad y costo de delivery? 🍣`;
      window.open(
        `https://wa.me/51941442899?text=${encodeURIComponent(msg)}`,
        "_blank",
      );
    });

    const menuGrid = document.getElementById("menuGrid");
    menuGrid?.addEventListener("click", (event) => {
      if (!(event.target instanceof HTMLElement)) return;
      const btn = event.target.closest(".add-btn");
      if (!(btn instanceof HTMLElement)) return;
      const card = btn.closest(".menu-card");
      if (!(card instanceof HTMLElement)) return;
      addToCart(
        String(card.dataset.id),
        String(card.dataset.name),
        String(card.dataset.price),
        String(card.dataset.img),
      );
      btn.textContent = "✓";
      btn.classList.add("added");
      setTimeout(() => {
        btn.textContent = "+";
        btn.classList.remove("added");
      }, 1500);
    });

    document.querySelectorAll(".combo-add").forEach((btn) => {
      if (!(btn instanceof HTMLElement)) return;
      btn.addEventListener("click", () => {
        const card = btn.closest(".combo-card");
        if (!(card instanceof HTMLElement)) return;
        addToCart(
          String(card.dataset.id),
          String(card.dataset.name),
          String(card.dataset.price),
          String(card.dataset.img),
        );
        toggleCart(true);
      });
    });

    /** @param {boolean} open */
    const toggleCart = (open) => {
      const cartOverlay = document.getElementById("cartOverlay");
      const cartDrawer = document.getElementById("cartDrawer");
      cartDrawer?.classList.toggle("open", open);
      cartOverlay?.classList.toggle("open", open);
      document.body.style.overflow = open ? "hidden" : "";
    };
  };

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", initCart);
  } else {
    initCart();
  }

  // // ── REVEAL ON SCROLL ──
  // const observer = new IntersectionObserver(
  //   (entries) => {
  //     entries.forEach((e) => {
  //       if (e.isIntersecting) {
  //         e.target.classList.add("visible");
  //         observer.unobserve(e.target);
  //       }
  //     });
  //   },
  //   { threshold: 0.15 },
  // );
  // document.querySelectorAll(".reveal").forEach((el) => observer.observe(el));
</script>
