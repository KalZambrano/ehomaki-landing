---
interface Props {
  id: string;
  name: string;
  shortName: string;
  price: number;
  pieces: string;
  description: string;
  slug: string;
}

const { id, name, shortName, price, pieces, description, slug } = Astro.props;
---

<article
  class="group relative overflow-hidden flex flex-col h-85
    border border-[#1b1812]
    bg-[#090806]
    p-6 md:p-8
    text-center
    transition-all duration-500
    hover:border-[#c89b3c]/40 hover:-translate-y-1"
  data-id={id}
  data-name={name}
  data-price={price}
>
  {/* Glow */}
  <div
    class="pointer-events-none absolute inset-0 opacity-0
      transition-opacity duration-500
      group-hover:opacity-100"
  >
    <div
      class="absolute inset-0
        bg-[radial-gradient(circle_at_top,rgba(200,155,60,0.10),transparent_60%)]"
    >
    </div>
  </div>

  {/* Bottom line */}
  <div
    class="absolute bottom-0 left-0 right-0 h-px
      origin-center scale-x-0
      bg-linear-to-r
      from-transparent via-[#c89b3c] to-transparent
      transition-transform duration-500
      group-hover:scale-x-100"
  >
  </div>

  <section class="relative z-10 flex h-full flex-col justify-between">
    <header>
      {/* Name */}
      <h3
        class="mt-2
          font-['Noto_Serif_JP']
          text-xl font-bold
          text-[#f5f1ea]"
        transition:name={`combo-${slug}`}
      >
        {shortName}
      </h3>

      {/* Divider */}
      <div
        class="my-5 flex items-center justify-center gap-2"
        role="separator"
        aria-orientation="horizontal"
      >
        <div class="h-px w-10 bg-[#c89b3c]/30"></div>
        <div class="size-1 rounded-full bg-[#c89b3c]"></div>
        <div class="h-px w-10 bg-[#c89b3c]/30"></div>
      </div>

      {/* Description */}
      <p
        class="mx-auto max-w-65
          text-sm leading-7
          text-[#cfc5b6]"
        transition:name={`combo-${slug}-description`}
      >
        {description}
      </p>
    </header>

    {/* Bottom */}
    <footer class="mt-10">
      <p
        class="mb-6
          font-['Bebas_Neue']
          text-5xl leading-none
          text-[#c89b3c]"
        transition:name={`combo-${slug}-price`}
      >
        S/ {price}
      </p>

      <a
        href={`/combos/${slug}`}
        class="group
    inline-flex
    items-center
    gap-3
    text-[#c89b3c]
    uppercase
    tracking-[0.3em]
    text-xs
    transition-colors duration-300
    hover:text-[#f5f1ea]"
      >
        Ver detalles

        <span
          class="flex items-center justify-center
      size-8
      border border-[#c89b3c]/30
      rounded-full
      transition-all duration-300
      group-hover:border-[#c89b3c]
      group-hover:translate-x-1"
        >
          →
        </span>
      </a>
    </footer>
  </section>
</article>
