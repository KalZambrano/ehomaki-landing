---
interface Props {
  id: string;
  name: string;
  shortName: string;
  price: number;
  pieces: string;
  description: string;
}

const { id, name, shortName, price, pieces, description } = Astro.props;
---

<div
  class="group relative overflow-hidden
    border border-[#1b1812]
    bg-[#090806]
    p-6 md:p-8
    text-center
    transition-colors duration-300
    hover:bg-[#100d09]"
  data-id={id}
  data-name={name}
  data-price={price}
>
  {/* Glow */}
  <div
    class="pointer-events-none absolute inset-0 opacity-0
      transition-opacity duration-500
      group-hover:opacity-100"
  >
    <div
      class="absolute inset-0
        bg-[radial-gradient(circle_at_top,rgba(200,155,60,0.10),transparent_60%)]"
    >
    </div>
  </div>

  {/* Bottom line */}
  <div
    class="absolute bottom-0 left-0 right-0 h-px
      origin-center scale-x-0
      bg-linear-to-r
      from-transparent via-[#c89b3c] to-transparent
      transition-transform duration-500
      group-hover:scale-x-100"
  >
  </div>

  <div class="relative z-10 flex h-full flex-col justify-between">
    <div>
      {/* Pieces */}
      <div
        class="font-['Bebas_Neue']
          text-[5rem] leading-none
          text-[#c89b3c]/20
          transition-all duration-500
          group-hover:text-[#c89b3c]/30
          group-hover:scale-105
          md:text-[6rem]"
      >
        {pieces}
      </div>

      {/* Name */}
      <h3
        class="mt-2
          font-['Noto_Serif_JP']
          text-xl font-bold
          text-[#f5f1ea]"
      >
        {shortName}
      </h3>

      {/* Divider */}
      <div class="my-5 flex items-center justify-center gap-2">
        <div class="h-px w-10 bg-[#c89b3c]/30"></div>
        <div class="size-1 rounded-full bg-[#c89b3c]"></div>
        <div class="h-px w-10 bg-[#c89b3c]/30"></div>
      </div>

      {/* Description */}
      <p
        class="mx-auto max-w-65
          text-sm leading-7
          text-[#cfc5b6]"
      >
        {description}
      </p>
    </div>

    {/* Bottom */}
    <div class="mt-10">
      <div
        class="mb-6
          font-['Bebas_Neue']
          text-5xl leading-none
          text-[#c89b3c]"
      >
        S/ {price}
      </div>

      <button
        type="button"
        class="group/btn relative w-full overflow-hidden cursor-pointer
          border border-[#c89b3c]/70
          bg-transparent
          px-6 py-4
          text-xs font-medium
          uppercase tracking-[0.25em]
          text-[#c89b3c]
          transition-all duration-300
          hover:text-black"
      >
        {/* Hover bg */}
        <span
          class="absolute inset-0
            origin-left scale-x-0
            bg-[#c89b3c]
            transition-transform duration-300 ease-out
            group-hover/btn:scale-x-100"
        ></span>

        {/* Content */}
        <span
          class="relative z-10
            flex items-center justify-center gap-3"
        >
          Ordenar

          <span
            class="transition-transform duration-300
              group-hover/btn:translate-x-1"
          >
            →
          </span>
        </span>
      </button>
    </div>
  </div>
</div>
