---
import ComboCard from "./cards/ComboCard.astro";
import SectionContainer from "../components/SectionContainer.astro";

const COMBOS = [
  {
    id: "c1",
    name: "Box Infarto 30 pz",
    shortName: "Box Infarto",
    price: 55,
    pieces: "30",
    description:
      "3 sabores de makis a elección. Ideal para compartir entre 2-3 personas.",
  },
  {
    id: "c2",
    name: "Box 40 Makis",
    shortName: "Box 40 Makis",
    price: 69,
    pieces: "40",
    description:
      "4 sabores a elección. La opción más popular para grupos medianos.",
  },
  {
    id: "c3",
    name: "Box 50 Makis",
    shortName: "Box 50 Makis",
    price: 90,
    pieces: "50",
    description: "5 sabores a elección. Para los verdaderos amantes del sushi.",
  },
  {
    id: "c4",
    name: "Combo Premium",
    shortName: "Combo Premium",
    price: 125,
    pieces: "★",
    description:
      "50 piezas + alitas (teriyaki, acevichadas y maracuyá). La experiencia completa.",
  },
];
---

<SectionContainer title="Boxes & Combos" subtitle="Para el grupo" name="combos">
  <div class="grid grid-cols-2 lg:grid-cols-4 gap-px bg-[#1b1812]">
    {
      COMBOS.map((combo) => (
        <ComboCard
          id={combo.id}
          name={combo.name}
          shortName={combo.shortName}
          price={combo.price}
          pieces={combo.pieces}
          description={combo.description}
        />
      ))
    }
  </div>
</SectionContainer>

<style>
  .combos-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1px;
    background: var(--border);
  }
</style>
