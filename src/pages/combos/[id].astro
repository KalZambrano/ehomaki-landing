---
import type { GetStaticPaths } from "astro";
import { COMBOS } from "@/const/combos";
import { CATEGORIAS } from "@/const/carta";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import { SelectVariety } from "@/components/SelectVariety";
import { AddButton } from "@/components/ui/add-button";
import ArrowLeft from "@/assets/icons/arrow-left.svg";

export const getStaticPaths = (() => {
  return COMBOS.map((combo) => ({
    params: { id: combo.slug },
    props: { combo },
  }));
}) satisfies GetStaticPaths;

const { combo } = Astro.props;

const allVarieties = CATEGORIAS.filter(
  (cat) => cat.id !== "complementos",
).flatMap((cat) =>
  cat.items.map((item) => ({
    name: item.nombre,
    ingredients: item.ingredientes,
    category: cat.label,
  })),
);
---

<Layout>
  <Header />

  <section class="mx-auto max-w-7xl px-6 py-20 sm:px-8 md:py-24 lg:px-8">
    <a
      href="/combos"
      class="inline-flex
    items-center
    gap-2
    mb-8
    text-sm
    uppercase
    tracking-[0.15em]
    text-[#c89b3c]
    transition-all
    duration-300
    hover:text-[#f5f1ea]
    hover:-translate-x-1"
    >
      <ArrowLeft class="size-4" />
      Volver a Combos
    </a>
    <div
      class="grid gap-6 lg:grid-cols-[minmax(0,1.35fr)_minmax(360px,0.65fr)] lg:items-stretch"
    >
      <div
        class="group relative min-h-80 overflow-hidden rounded-[28px] border border-[#c89b3c]/20 bg-[#0c0a07] md:min-h-115"
      >
        <img
          src={combo.image}
          alt={combo.description}
          class="absolute inset-0 h-full w-full object-cover transition-transform duration-700 group-hover:scale-105"
          transition:name={`combo-${combo.slug}-image`}
        />
        <div
          class="absolute inset-0 bg-linear-to-t from-[#090806] via-[#090806]/20 to-transparent"
        >
        </div>
        <div class="absolute bottom-0 left-0 right-0 p-6 md:p-8">
          <span
            class="inline-flex rounded-full border border-[#c89b3c]/30 bg-black/45 px-3 py-1 text-xs font-semibold uppercase tracking-[0.22em] text-[#c89b3c] backdrop-blur"
          >
            {combo.portion ? `${combo.portion} piezas` : combo.type}
          </span>
          <h1
            class="mt-4 font-['Noto_Serif_JP'] text-4xl font-bold leading-tight text-[#f5f1ea] md:text-6xl"
            transition:name={`combo-${combo.slug}`}
          >
            {combo.name}
          </h1>
          <p
            class="mt-3 max-w-2xl text-base leading-relaxed text-[#e5d8c4] md:text-lg"
            transition:name={`combo-${combo.slug}-description`}
          >
            {combo.shortDescription}
          </p>
        </div>
      </div>

      <aside
        class="flex flex-col justify-between rounded-[28px] border border-[#c89b3c]/15 bg-[#0c0a07] p-6 md:p-7"
      >
        <div>
          <p
            class="text-xs font-semibold uppercase tracking-[0.28em] text-[#c89b3c]"
          >
            Incluye
          </p>
          <div class="mt-5 grid gap-3">
            {
              combo.includes.map((item) => (
                <div class="flex items-center gap-3 rounded-2xl border border-[#c89b3c]/10 bg-[#15110c] px-4 py-3 text-sm leading-snug text-[#f5f1ea]">
                  <span class="grid size-6 shrink-0 place-items-center rounded-full bg-[#c89b3c]/15 text-sm font-bold text-[#c89b3c]">
                    ✓
                  </span>
                  <span>{item}</span>
                </div>
              ))
            }
          </div>
        </div>

        <div
          class="mt-8 rounded-3xl border border-[#c89b3c]/15 bg-[#090806] p-5"
        >
          <p
            class="text-xs font-semibold uppercase tracking-[0.24em] text-[#cfc5b6]/70"
          >
            Precio
          </p>
          <div class="mt-2 flex items-end gap-2">
            <span
              class="font-['Bebas_Neue'] text-7xl leading-none text-[#c89b3c] md:text-8xl"
              transition:name={`combo-${combo.slug}-price`}
            >
              S/ {combo.price}
            </span>
          </div>
          <p class="mt-2 text-sm text-[#cfc5b6]/70">Total del combo</p>
        </div>
      </aside>
    </div>

    {
      combo.canChooseVarieties && (
        <SelectVariety
          client:load
          varietiesCount={combo.varietiesCount || 0}
          allVarieties={allVarieties}
          name={combo.name}
        />
      )
    }

    {
      !combo.canChooseVarieties && (
        <AddButton client:load combo={{ name: combo.name }} />
      )
    }
  </section>
</Layout>
